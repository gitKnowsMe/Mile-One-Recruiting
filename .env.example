# Neon Postgres connection string (Vercel Marketplace > Neon integration)
DATABASE_URL=

# Vercel Blob read/write token (Vercel dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN=

# Resend API key (resend.com/api-keys)
RESEND_API_KEY=

# Verified Resend sending domain address, e.g. applications@yourdomain.com
APPLICATIONS_FROM_EMAIL=

# Internal recipient notified of every new application (optional)
APPLICATIONS_NOTIFY_EMAIL=mile1recruiting@gmail.com
